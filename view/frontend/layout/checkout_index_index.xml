<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Paywall init script (vanilla JS — Hyvä/Luma/Blank compatible, no Knockout/RequireJS) -->
        <script src="Comfino_ComfinoGateway::js/paywall-init.js" defer="true"/>
    </head>
    <body>
        <!-- Inject Comfino payment block into checkout payment methods area -->
        <referenceContainer name="checkout.payment.methods">
            <block class="Comfino\ComfinoGateway\Block\Payment\Comfino"
                   name="comfino.payment"
                   template="Comfino_ComfinoGateway::payment/comfino.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
