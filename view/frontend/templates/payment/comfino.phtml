/** @var \Magento\Framework\Escaper $escaper */
?>

<!-- Comfino web frontend SDK from CDN -->
<script src="<?= $escaper->escapeUrl($block->getSdkScriptUrl()) ?>"></script>

<!-- Hidden form fields — written by onUpdateOrderPaymentState callback, read on order submit -->
<input id="comfino-loan-type" name="comfino_loan_type" type="hidden" />
<input id="comfino-loan-term" name="comfino_loan_term" type="hidden" />

<!-- SDK renders paywall iframe here -->
<div id="comfino-paywall-container" style="min-height:60px;"></div>

<script>
window.ComfinoPaywallData = {
    paywallUrl: '<?= $escaper->escapeJs($block->getPaywallUrl()) ?>',
    environment: '<?= $escaper->escapeJs($block->getEnvironment()) ?>'
};
// Signal to paywall-init.js that the payment method is active and this block was rendered.
window.Comfino = window.Comfino || {};
window.Comfino.active = true;
if (typeof ComfinoPaywallInit === 'object') {
    ComfinoPaywallInit.init();
}
</script>
