<?php
/** @var \Comfino\ComfinoGateway\Block\Payment\Comfino $block */
/** @var \Magento\Framework\Escaper $escaper */
?>
<div
    x-data="comfinoPaywall()"
    x-init="init()"
    @comfino-paywall-reload.window="reload($event.detail)"
>
    <!-- Loan parameters written by MagentoAdapter.updatePaymentState(), read on order submission -->
    <input id="comfino-loan-type" name="comfino_loan_type" type="hidden" />
    <input id="comfino-loan-term" name="comfino_loan_term" type="hidden" />

    <!-- Comfino web frontend SDK renders the paywall iframe here -->
    <div id="comfino-paywall-container"></div>
</div>

<script>
function comfinoPaywall() {
    return {
        paywall: null,

        init() {
            const data = {
                authToken:   '<?= $escaper->escapeJs($block->getAuthToken()) ?>',
                loanAmount:  <?= (int) $block->getLoanAmount() ?>,
                environment: '<?= $escaper->escapeJs($block->getEnvironment()) ?>',
                platform:    'magento'
            };

            const sdkUrl = '<?= $escaper->escapeUrl($block->getSdkScriptUrl()) ?>';

            // Guard: SDK may already be present if the customer navigated back to the payment step.
            if (document.querySelector('script[data-comfino-sdk]')) {
                if (window.Comfino) {
                    this.paywall = window.Comfino.bootstrapPaywall('magento', data);
                }
                return;
            }

            // Temporarily hide window.define so the SDK's UMD bundle takes the
            // global-assignment branch and exposes window.Comfino.
            // Alpine.js does not use AMD, but some merchants install RequireJS-based
            // extensions alongside Hyvä Theme — the guard keeps things safe in that case.
            const _amdDefine = window.define;
            window.define = undefined;

            const script = document.createElement('script');
            script.src = sdkUrl;
            script.setAttribute('data-comfino-sdk', '1');
            script.onload = () => {
                window.define = _amdDefine;
                this.paywall = window.Comfino.bootstrapPaywall('magento', data);
            };
            script.onerror = () => {
                window.define = _amdDefine;
            };
            document.head.appendChild(script);
        },

        /**
         * Reload the paywall with an updated loan amount.
         *
         * Dispatch this event from the Hyvä Checkout cart/totals Magewire component
         * whenever the cart grand total changes (coupon applied, shipping selected, etc.):
         *
         *   PHP side (Magewire component):
         *     $this->dispatchBrowserEvent('comfino-paywall-reload', [
         *         'loanAmount' => (int) round($quote->getGrandTotal() * 100)
         *     ]);
         *
         * The SDK's MagentoPaywallController.reload() re-fetches offers for the new
         * amount without destroying and recreating the iframe.
         *
         * @param {{ loanAmount: number }} detail
         */
        reload(detail) {
            if (this.paywall && detail && detail.loanAmount) {
                this.paywall.reload({ loanAmount: detail.loanAmount });
            }
        }
    };
}
</script>