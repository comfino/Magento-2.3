<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="checkout.payment.methods">
            <!--
                The "as" attribute MUST match the Magento payment method code exactly.
                The block class provides getAuthToken(), getLoanAmount(), getSdkScriptUrl(),
                getEnvironment(), and getAllowedProductTypeStrings() to the template.
            -->
            <block name="checkout.payment.method.comfino"
                   as="comfino"
                   class="Comfino\ComfinoGateway\Block\Payment\Comfino"
                   template="Comfino_ComfinoGatewayHyvaCheckout::hyva-checkout/payment/comfino.phtml"/>
        </referenceBlock>
    </body>
</page>