<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <payment>
            <comfino>
                <active>0</active>
                <title>Comfino (Raty | Kup Teraz, Zapłać Później | Finansowanie dla Firm)</title>
                <paywall_title>Comfino - raty i płatności odroczone</paywall_title>
                <order_status>pending_payment</order_status>
                <model>ComfinoFacade</model>
                <group>offline</group>
                <can_use_checkout>1</can_use_checkout>
                <min_order_total>30</min_order_total>
                <widget_enabled>0</widget_enabled>
                <widget_price_selector>span.price</widget_price_selector>
                <widget_target_selector>div.product-info-main</widget_target_selector>
                <widget_price_observer_selector />
                <widget_price_observer_level>0</widget_price_observer_level>
                <widget_type>with-modal</widget_type>
                <widget_offer_type>CONVENIENT_INSTALLMENTS</widget_offer_type>
                <widget_embed_method>INSERT_INTO_LAST</widget_embed_method>
                <use_order_reference>0</use_order_reference>
                <product_category_filters />
                <widget_show_provider_logos>0</widget_show_provider_logos>
                <widget_custom_banner_css_url />
                <widget_custom_calculator_css_url />
                <debug>0</debug>
                <service_mode>0</service_mode>
                <dev_env_vars>0</dev_env_vars>
                <widget_prod_script_version />
                <widget_dev_script_version />
                <cat_filter_avail_prod_types>INSTALLMENTS_ZERO_PERCENT,PAY_LATER,COMPANY_BNPL,COMPANY_INSTALLMENTS,LEASING,PAY_IN_PARTS</cat_filter_avail_prod_types>
                <prod_cat_cache_ttl>3600</prod_cat_cache_ttl>
                <initial_order_status>comfino_created</initial_order_status>
                <ignored_statuses>WAITING_FOR_FILLING,WAITING_FOR_CONFIRMATION,WAITING_FOR_PAYMENT,PAID</ignored_statuses>
                <forbidden_statuses>RESIGN</forbidden_statuses>
                <status_map>{"ACCEPTED":"comfino_accepted","CANCELLED":"comfino_cancelled","REJECTED":"comfino_rejected","CANCELLED_BY_SHOP":"comfino_cancelled_by_shop"}</status_map>
                <api_connect_timeout>3</api_connect_timeout>
                <api_timeout>5</api_timeout>
                <api_connect_num_attempts>3</api_connect_num_attempts>
                <widget_code />
            </comfino>
        </payment>
    </default>
</config>
